        {
          "rank": 6,
          "condition": "default",
          "action": "advance-with-cover",
          "cardText": "Otherwise: Move toward an elevated position or cover with long sightlines."
        }
      ],
      "weights": {
        "killPotential": 10,
        "coverValue": 9,
        "proximity": 1,
        "threatLevel": 6,
        "elevation": 10,
        "selfPreservation": 8,
        "aimValue": 8,
        "dodgeValue": 4
      }
    },
    "melee": {
      "id": "melee",
