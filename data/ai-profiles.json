        {
          "rank": 5,
          "condition": "default",
          "action": "move-toward-enemy",
          "cardText": "Otherwise: Move as close as possible to the nearest enemy."
        }
      ],
      "weights": {
        "killPotential": 10,
        "coverValue": 1,
        "proximity": 10,
        "threatLevel": 5,
        "elevation": 1,
        "selfPreservation": 2,
        "aimValue": 0,
        "dodgeValue": 3
      }
    },
